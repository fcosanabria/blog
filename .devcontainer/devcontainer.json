{
  "name": "Francisco's blog",
  "image": "mcr.microsoft.com/devcontainers/jekyll:2-bullseye",
  "postCreateCommand": "bundle install",
  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "Jekyll",
      "onAutoForward": "openBrowser"
    }
  },
  "remoteUser": "vscode"
}
